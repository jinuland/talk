# --- Database ---
# Default: local SQLite. For production, switch to a Postgres URL.
DATABASE_URL="file:./dev.db"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="please-change-me-in-production"

# --- Anthropic (Claude) ---
# Optional. If unset, the app falls back to a deterministic mock agenda generator.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- Stripe ---
# Optional. If unset, checkout uses a local mock that auto-confirms after 2s.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Zoom ---
# Optional. If unset, meeting links are mock URLs.
ZOOM_ACCOUNT_ID=""
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
